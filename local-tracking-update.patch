+            break
+        for item in items_by_regulation.get(regulation["id"], [])[:guaranteed_count]:
+            if len(selected_by_key) >= limit:
+                break
+            add_item(item)
+
+    remaining_pool = [
+        item
+        for regulation in regulations
+        for item in items_by_regulation.get(regulation["id"], [])
